{
  "buildCommand": "vite build && ./node_modules/.bin/esbuild api/index.ts --bundle --platform=node --packages=external --format=esm --outfile=api/index.js",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
