{
  "buildCommand": "vite build && ./node_modules/.bin/esbuild server/vercel-handler.ts --bundle --platform=node --format=cjs --external:bufferutil --external:utf-8-validate --external:pg-native --outfile=api/index.cjs",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
